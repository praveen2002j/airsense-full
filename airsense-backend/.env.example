PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/airsense

# ThingSpeak
THINGSPEAK_CHANNEL_ID=3307435
THINGSPEAK_READ_API_KEY=your_read_api_key_here
THINGSPEAK_POLL_INTERVAL_MS=15000

# Field mapping (match your ThingSpeak channel field order)
FIELD_CO2=field1
FIELD_TEMPERATURE=field2
FIELD_HUMIDITY=field3
FIELD_CO=field4
FIELD_OCCUPANCY=field5

# Alert thresholds
CO2_WARNING=1000
CO2_CRITICAL=1500
CO_WARNING=9
CO_CRITICAL=35
TEMP_WARNING=28
HUMIDITY_LOW=30
HUMIDITY_HIGH=70
